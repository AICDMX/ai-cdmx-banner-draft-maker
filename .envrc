# direnv: load API keys from a local .env file (not committed).
# Setup:
#   1. cp .env.example .env  &&  edit .env with your real keys
#   2. direnv allow
#
# If the local Codex/Claude cliproxy env exists, prefer that for the OpenAI
# backend so banner_api_cli.py uses the same OpenAI-compatible endpoint/key as
# the local `co` wrapper. No secret is committed here; values come from the
# user's private ~/.config/claude-aliases/env file.
dotenv_if_exists .env

cliproxy_env="$HOME/.config/claude-aliases/env"
if [ -r "$cliproxy_env" ]; then
  # shellcheck disable=SC1090
  source "$cliproxy_env"
  if [ -n "${CLIPROXY_API_KEY:-}" ]; then
    export CLIPROXY_API_KEY
    export OPENAI_API_KEY="$CLIPROXY_API_KEY"
  fi
  if [ -n "${CLIPROXY_BASE_URL:-}" ]; then
    export CLIPROXY_BASE_URL
    case "${CLIPROXY_BASE_URL%/}" in
      */v1) export OPENAI_BASE_URL="${CLIPROXY_BASE_URL%/}" ;;
      *) export OPENAI_BASE_URL="${CLIPROXY_BASE_URL%/}/v1" ;;
    esac
  fi
fi
