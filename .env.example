# Copy to .env and fill in real keys. .env is gitignored; load it with `direnv allow`.
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
# GOOGLE_API_KEY is accepted as a fallback for Gemini.

# Optional OpenAI-compatible custom endpoint/proxy. The value should be the API
# root used by the OpenAI SDK, usually ending in /v1.
# OPENAI_BASE_URL=http://localhost:8317/v1

# If OPENAI_API_KEY is unset, the OpenAI backend also accepts CLIPROXY_API_KEY
# and CLIPROXY_BASE_URL from the environment or from:
#   ~/.config/claude-aliases/env
# CLIPROXY_API_KEY=your_cliproxy_key
# CLIPROXY_BASE_URL=http://forgejo-cliproxy:8317

# Optional model overrides (otherwise defaults from image_apis.py are used):
# OPENAI_MODEL=gpt-5.5
# GEMINI_MODEL=gemini-3.1-flash-image-preview
